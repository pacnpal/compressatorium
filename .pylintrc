; Project-wide pylint configuration.
; Codacy reads this file directly (config_file: .pylintrc in .codacy.yml).
; pyproject.toml [tool.pylint] and .prospector.yaml mirror the Codacy-relevant
; disables declared here so all lint entry-points stay in sync.
; Note: plugin-specific IDs (e.g. I1010/django-not-configured from pylint-django)
; are kept here and in .prospector.yaml (Codacy ships the plugin) but intentionally
; omitted from pyproject.toml to avoid W0012 noise on local installs without the plugin.

[MAIN]
py-version = 3.10
init-hook = "import sys; sys.path.insert(0, 'app')"
ignore = .venv,venv,node_modules,app/.venv,static/vendor

[MESSAGES CONTROL]
disable =
    C0111,
    C0112,
    C0114,
    C0115,
    C0116,
    missing-docstring,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    missing-method-docstring,
    E1136,
    unsubscriptable-object,
    R0901,
    R0902,
    R0903,
    R0911,
    R0912,
    R0913,
    R0914,
    R0915,
    R0916,
    R0917,
    too-many-ancestors,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-boolean-expressions,
    too-many-branches,
    too-many-instance-attributes,
    too-many-locals,
    too-many-public-methods,
    too-many-return-statements,
    too-many-statements,
    too-few-public-methods,
    C0415,
    import-outside-toplevel,
    W0212,
    protected-access,
    W0621,
    redefined-outer-name,
    W0613,
    unused-argument,
    W0703,
    W0718,
    broad-except,
    broad-exception-caught,
    C0103,
    invalid-name,
    C0330,
    bad-continuation,
    R0801,
    duplicate-code,
    W0603,
    global-statement,
    C0303,
    trailing-whitespace,
    R0201,
    no-self-use,
    C0411,
    wrong-import-order,
    W0107,
    unnecessary-pass,
    C0326,
    bad-whitespace,
    R1716,
    chained-comparison,
    R1702,
    too-many-nested-blocks,
    R1715,
    consider-using-get,
    W0640,
    cell-var-from-loop,
    W1203,
    logging-fstring-interpolation,
    C0302,
    too-many-lines,
    I0011,
    locally-disabled,
    E0012,
    bad-option-value,
    E0611,
    no-name-in-module,
    E0401,
    import-error,
    E1101,
    no-member,
    E0001,
    syntax-error,
    I1010,
    django-not-configured,
    R1732,
    consider-using-with

[FORMAT]
max-line-length = 100
indent-string = '    '

[DESIGN]
max-line-length = 100

[SIMILARITIES]
min-similarity-lines = 10
ignore-imports = yes
ignore-docstrings = yes
ignore-comments = yes
