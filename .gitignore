# ============ Svelte/Vite frontend build outputs ============
# Vite emits index.html + hashed assets directly into static/ via vite.config.js.
# These are regenerated by `npm run build` (and by the Docker frontend-builder
# stage in CI); source lives under src/. Do not commit build artifacts.
/static/index.html
/static/assets/

# The Python gitignore template ignores `lib/` (used by virtualenvs). Re-include
# the Svelte source folder under src/lib so frontend modules are tracked.
!/src/lib/
!/src/lib/**
